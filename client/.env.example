# Base das chamadas da API (axios). Use /api em dev e prod: o proxy do Vite (dev)
# e o reverse proxy (prod) encaminham para o backend tirando o prefixo /api.
VITE_API_BASE_URL=/api

# Dev-only: para onde o proxy do Vite encaminha /api. Aponte para o seu backend.
# server.js usa a porta PORT do server/.env (default 3003); o docker usa 3032.
# Descomente/ajuste se o seu backend NÃO estiver em 3003.
# VITE_API_PROXY_TARGET=http://localhost:3003
