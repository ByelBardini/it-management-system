DB_DATABASE= nome-database
DB_USER= usuario-database
DB_PASSWORD= senha-database
DB_HOST= host-database
DB_PORT= porta-database

SECRET_KEY_PASSWORD= secret-key-para-criptografia-das-senhas
SECRET_KEY_LOGIN= secret-key-para-login

# Seed (npm run db:seed) — todos opcionais; estes são os defaults.
# O admin entra direto (usuario_troca_senha=0). Troque a senha em produção.
SEED_ADMIN_LOGIN= admin
SEED_ADMIN_SENHA= admin123
SEED_ADMIN_NOME= Administrador
SEED_EMPRESA_NOME= Empresa Padrão
SEED_EMPRESA_CNPJ= 00.000.000/0001-00