DB_DATABASE= nome-database
DB_USER= usuario-database
DB_PASSWORD= senha-database
DB_HOST= host-database
DB_PORT= porta-database

# Use chaves FORTES em produção. SECRET_KEY_PASSWORD deve ter EXATAMENTE 32
# caracteres (AES-256-CBC); o app não sobe se faltar/tiver tamanho errado.
SECRET_KEY_PASSWORD= secret-key-para-criptografia-das-senhas
SECRET_KEY_LOGIN= secret-key-para-login

# Porta da API. Em dev o default é 3003; o Coolify injeta a sua.
PORT= 3003

# production em deploy (ativa cookie secure e exige CORS_ORIGIN). Deixe vazio em dev.
NODE_ENV=

# Origens permitidas (CSRF + CORS), separadas por vírgula. OBRIGATÓRIO em produção.
# Coloque o(s) domínio(s) do FRONT. Ex.: https://infrahub.suaempresa.com
# Em dev pode deixar vazio (libera localhost). Inclua http://localhost:5173 se quiser testar CORS.
CORS_ORIGIN=

# Força o atributo Secure do cookie de sessão (true em HTTPS). Se vazio, segue NODE_ENV.
COOKIE_SECURE=

# Seed (npm run db:seed) — todos opcionais; estes são os defaults.
# O admin entra direto (usuario_troca_senha=0). Troque a senha em produção.
SEED_ADMIN_LOGIN= admin
SEED_ADMIN_SENHA= admin123
SEED_ADMIN_NOME= Administrador
SEED_EMPRESA_NOME= Empresa Padrão
SEED_EMPRESA_CNPJ= 00.000.000/0001-00
